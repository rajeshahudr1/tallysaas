<%
/* ─────────────────────────────────────────────────────────────
 * views/receipts/list.ejs — TRANSACTIONS · Receipts.
 * Route: GET /receipts  ·  activeMenu: 'receipts'.
 *
 * Money received from customers (Tally Receipt Vouchers).
 *
 * Expected locals (routes/web.js → res.render):
 *   receiptRows     [ rows ]   — table body
 *   receiptsTotal   number     — pagination total
 *   page, perPage   numbers
 *   customerNames / paymentModes / invoiceStatuses — filter options
 * ─────────────────────────────────────────────────────────── */

var _rows     = (typeof receiptRows !== 'undefined' && receiptRows) ? receiptRows : [];
var _total    = (typeof receiptsTotal !== 'undefined') ? receiptsTotal : _rows.length;
var _page     = (typeof page !== 'undefined' && page) ? page : 1;
var _perPage  = (typeof perPage !== 'undefined' && perPage) ? perPage : 10;
var _custs    = (typeof customerNames !== 'undefined' && customerNames) ? customerNames : [];
var _modes    = (typeof paymentModes !== 'undefined' && paymentModes) ? paymentModes : [];
var _statuses = (typeof invoiceStatuses !== 'undefined' && invoiceStatuses) ? invoiceStatuses : [];

function _opts(all, list) {
    var out = [{ value: '', label: all }];
    (list || []).forEach(function (v) { out.push({ value: v, label: v }); });
    return out;
}

/* ── FilterCard config (5 fields) ───────────────────────────── */
var filterFields = [
    { type: 'text',   name: 'search',    label: 'Search',    placeholder: 'Receipt no / customer...', colClass: 'filter-col-fifth' },
    { type: 'select', name: 'customer',  label: 'Customer',  options: _opts('All Customers', _custs), colClass: 'filter-col-fifth' },
    { type: 'select', name: 'mode',      label: 'Mode',      options: _opts('All Modes', _modes),     colClass: 'filter-col-fifth' },
    { type: 'select', name: 'status',    label: 'Status',    options: _opts('All Status', _statuses), colClass: 'filter-col-fifth' },
    { type: 'date',   name: 'date_from', label: 'Date From',                                          colClass: 'filter-col-fifth' },
];

/* ── Table config — Tally Receipt-Register order ────────────── */
var tableColumns = [
    { key: 'date',       label: 'Date',        sortable: true,  type: 'date' },
    { key: 'party',      label: 'Particulars', sortable: true,  type: 'text' },
    { key: 'vch_type',   label: 'Vch Type',    sortable: false, type: 'text' },
    { key: 'receipt_no', label: 'Vch No.',     sortable: true,  type: 'text' },
    { key: 'amount',     label: 'Amount',      sortable: true,  type: 'currency' },
    { key: 'mode',       label: 'Mode',        sortable: true,  type: 'badge' },
    { key: 'status',     label: 'Status',      sortable: true,  type: 'status' },
];

var sortOptions = ['Date', 'Receipt No', 'Customer', 'Amount', 'Status'];
%>

<%- include('../partials/page-head', {
    title: 'Receipts',
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'Receipts' },
    ],
    actions: [
        { label: 'Export',      icon: 'fa-upload', variant: 'light',
          href: (typeof monthValue !== 'undefined' && monthValue) ? '/receipts/export?month=' + monthValue : '/receipts/export' },
        { label: 'Add Receipt', icon: 'fa-plus',   gradient: true, href: '/receipts/add' },
    ],
}) %>

<% if (typeof monthMode !== 'undefined' && monthMode) { %>
<div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
    <a href="/receipts" style="display:inline-flex;align-items:center;gap:6px;background:#fff;border:1px solid #cbd5e1;border-radius:8px;padding:7px 14px;color:#334155;text-decoration:none;font-weight:600;font-size:13px">
        <i class="fa-solid fa-arrow-left"></i> Receipt Register
    </a>
    <span style="font-size:15px;font-weight:700;color:#111"><%= typeof monthLabel !== 'undefined' ? monthLabel : '' %></span>
</div>
<% } %>

<form id="receipt-filters-form" autocomplete="off" method="get" action="/receipts">
    <% if (typeof monthValue !== 'undefined' && monthValue) { %>
    <input type="hidden" name="month" value="<%= monthValue %>">
    <% } %>
    <%- include('../partials/filter-card', {
        filterId: 'receipt-filters',
        title: 'Advanced Filters',
        fields: filterFields,
        collapsed: true,
    }) %>
</form>

<%# ── Total amount on top ── %>
<% var _gt  = (typeof grandTotal !== 'undefined') ? Number(grandTotal) : 0;
   var _cnt = (typeof receiptsTotal !== 'undefined') ? receiptsTotal : 0;
   function _inrG(v){ return Number(v||0).toLocaleString('en-IN',{minimumFractionDigits:2,maximumFractionDigits:2}); } %>
<div style="display:flex;gap:14px;margin-bottom:14px;flex-wrap:wrap">
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;padding:12px 18px;min-width:170px">
        <div style="font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:.4px">Total Vouchers</div>
        <div style="font-size:20px;font-weight:700;color:#111;margin-top:2px"><%= _cnt %></div>
    </div>
    <div style="background:linear-gradient(135deg,#10b981,#047857);color:#fff;border-radius:10px;padding:12px 18px;min-width:200px">
        <div style="font-size:11px;opacity:.85;text-transform:uppercase;letter-spacing:.4px">Total (Receipts)</div>
        <div style="font-size:20px;font-weight:700;margin-top:2px">₹ <%= _inrG(_gt) %></div>
    </div>
</div>

<div class="card">

    <div class="table-toolbar">
        <label class="toolbar-show mb-0">
            <span>Show</span>
            <select class="form-select form-select-sm" aria-label="Rows per page">
                <option value="10" selected>10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
            <span>entries</span>
        </label>
    </div>

    <%- include('../partials/table', {
        tableId: 'receipts-table',
        basePath: '/receipts',
        columns: tableColumns,
        rows: _rows,
        selectable: true,
        showIndex: true,
        actions: ['view', 'edit', 'delete'],
    }) %>

    <%- include('../partials/pagination', {
        page: _page,
        perPage: _perPage,
        total: _total,
    }) %>

</div>

<style>
    @media (min-width: 992px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 20%; }
    }
    @media (min-width: 768px) and (max-width: 991.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 33.3333%; }
    }
    @media (min-width: 576px) and (max-width: 767.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 50%; }
    }
    @media (max-width: 575.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 100%; }
    }
</style>
