<%
/* ─────────────────────────────────────────────────────────────
 * views/suppliers/form.ejs — Add / Edit Supplier (Tally Sundry Creditor).
 * Routes: GET /suppliers/add · GET /suppliers/:id/edit.
 *
 * Every tab maps to a REAL editable column on the `suppliers` table — the
 * old "coming next phase" placeholders + the Bank Details tab (no columns)
 * are gone. Synced Tally values pre-fill the inputs.
 *
 * Expected locals (routes/web.js → res.render):
 *   locationOptions [{id,name}] · supplierGroups [..] · paymentTerms [..]
 *   record — the row being edited (edit mode)  — optional
 * ─────────────────────────────────────────────────────────── */

var _rec    = (typeof record !== 'undefined' && record) ? record : null;
var _isEdit = !!_rec;
function _v(k){ return (_rec && _rec[k] != null) ? _rec[k] : ''; }

var _locOptions = (typeof locationOptions !== 'undefined' && locationOptions) ? locationOptions : [];
var _groups = (typeof supplierGroups !== 'undefined' && supplierGroups) ? supplierGroups : [];
var _terms  = (typeof paymentTerms !== 'undefined' && paymentTerms) ? paymentTerms : [];

var formTabs = [
    { id: 'basic',   label: 'Basic Information', icon: 'fa-id-card',          active: true },
    { id: 'address', label: 'Address',           icon: 'fa-map-location-dot'               },
    { id: 'gst',     label: 'GST & Tax Details',  icon: 'fa-percent'                        },
    { id: 'other',   label: 'Other Details',      icon: 'fa-circle-info'                    },
    { id: 'custom',  label: 'Custom Fields',      icon: 'fa-table-cells'                    },
];

function _selOpts(placeholder, list, current) {
    var html = '<option value=""' + (_isEdit ? '' : ' selected') + ' disabled hidden>' + placeholder + '</option>';
    (list || []).forEach(function (v) {
        var sel = (String(current) === String(v)) ? ' selected' : '';
        html += '<option value="' + v + '"' + sel + '>' + v + '</option>';
    });
    return html;
}
function _fkOpts(placeholder, list, current) {
    var html = '<option value=""' + (_isEdit ? '' : ' selected') + ' disabled hidden>' + placeholder + '</option>';
    (list || []).forEach(function (o) {
        var sel = (String(current) === String(o.id)) ? ' selected' : '';
        html += '<option value="' + o.id + '"' + sel + '>' + o.name + '</option>';
    });
    return html;
}

/* Custom Fields bag → key/value rows. */
var _cf = {};
try { var _raw = _rec ? _rec.custom_fields : null; _cf = (typeof _raw === 'string') ? JSON.parse(_raw || '{}') : (_raw || {}); } catch (e) { _cf = {}; }

var headActions =
    '<a class="btn btn-light" href="/suppliers">' +
        '<i class="fa-solid fa-arrow-left me-1"></i>Back to Suppliers' +
    '</a>' +
    '<button type="submit" form="supplier-form" class="btn btn-primary">' +
        '<i class="fa-solid fa-floppy-disk me-1"></i>' + (_isEdit ? 'Update' : 'Save') + ' Supplier' +
    '</button>';
%>

<%- include('../partials/page-head', {
    title: (_isEdit ? 'Edit' : 'Add') + ' Supplier',
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'Suppliers', href: '/suppliers' },
        { label: (_isEdit ? 'Edit' : 'Add') + ' Supplier' },
    ],
    actions: headActions,
}) %>

<form id="supplier-form" class="card form-card" method="post" action="<%= _isEdit ? '/suppliers/' + _rec.id : '/suppliers' %>" autocomplete="off" novalidate>

    <%- include('../partials/form-card', { tabs: formTabs }) %>

    <div class="tab-content form-card-body">

        <!-- ════ Basic Information ════ -->
        <div class="tab-pane fade show active" id="basic" role="tabpanel" aria-labelledby="basic-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="sup-name">Supplier Name<span class="req">*</span></label>
                    <input type="text" class="form-control" id="sup-name" name="name"
                           value="<%= _v('name') %>" placeholder="Enter supplier name" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="sup-mobile">Mobile Number</label>
                    <div class="input-affix">
                        <span class="affix affix--prefix"><i class="fa-solid fa-mobile-screen"></i></span>
                        <input type="tel" class="form-control" id="sup-mobile" name="mobile"
                               value="<%= _v('mobile') %>" placeholder="98765 43210" maxlength="30">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="sup-alt-mobile">Alternate Mobile</label>
                    <div class="input-affix">
                        <span class="affix affix--prefix"><i class="fa-solid fa-phone"></i></span>
                        <input type="tel" class="form-control" id="sup-alt-mobile" name="alternate_mobile"
                               value="<%= _v('alternate_mobile') %>" placeholder="Optional" maxlength="30">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="sup-group">Supplier Group</label>
                    <select class="form-select" id="sup-group" name="supplier_group">
                        <%- _selOpts('Select group', _groups, _v('supplier_group')) %>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="sup-email">Email</label>
                    <div class="input-affix">
                        <span class="affix affix--prefix"><i class="fa-solid fa-envelope"></i></span>
                        <input type="email" class="form-control" id="sup-email" name="email"
                               value="<%= _v('email') %>" placeholder="name@company.com">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="sup-location">Location<span class="req">*</span></label>
                    <select class="form-select" id="sup-location" name="location_id" required>
                        <%- _fkOpts('Select location', _locOptions, _v('location_id')) %>
                    </select>
                </div>
            </div>

            <hr class="form-divider">

            <div class="row g-4 align-items-start">
                <div class="col-12 col-md-7">
                    <label class="form-label d-block">Status<span class="req">*</span></label>
                    <div class="status-radios">
                        <label class="status-radio is-active">
                            <input type="radio" name="status" value="Active" <%= _isEdit ? (String(_v('status')) === 'Active' ? 'checked' : '') : 'checked' %>>
                            <span>Active</span>
                        </label>
                        <label class="status-radio is-inactive">
                            <input type="radio" name="status" value="Inactive" <%= String(_v('status')) === 'Inactive' ? 'checked' : '' %>>
                            <span>Inactive</span>
                        </label>
                        <label class="status-radio is-blocked">
                            <input type="radio" name="status" value="Blocked" <%= String(_v('status')) === 'Blocked' ? 'checked' : '' %>>
                            <span>Blocked</span>
                        </label>
                    </div>
                </div>
                <div class="col-12 col-md-5">
                    <label class="form-label d-block">Is Tally Ledger</label>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch"
                               id="sup-tally-ledger" name="is_tally_ledger" <%= _isEdit ? (_v('is_tally_ledger') ? 'checked' : '') : 'checked' %>>
                        <label class="form-check-label" for="sup-tally-ledger">Sundry Creditor</label>
                    </div>
                    <div class="form-hint">Creates this supplier under Sundry Creditors in Tally.</div>
                </div>
            </div>
        </div><!-- /#basic -->

        <!-- ════ Address ════ -->
        <div class="tab-pane fade" id="address" role="tabpanel" aria-labelledby="address-tab">
            <div class="row g-4">
                <div class="col-12 col-md-8">
                    <label class="form-label" for="sup-address">Address</label>
                    <textarea class="form-control" id="sup-address" name="address"
                              rows="4" maxlength="2000" placeholder="Building, street, area, city, state, pincode…"><%= _v('address') %></textarea>
                    <div class="form-hint">As it appears in Tally (state, pincode may be combined here).</div>
                </div>
            </div>
        </div><!-- /#address -->

        <!-- ════ GST & Tax Details ════ -->
        <div class="tab-pane fade" id="gst" role="tabpanel" aria-labelledby="gst-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="sup-gst">GST Number</label>
                    <input type="text" class="form-control text-uppercase" id="sup-gst" name="gst_number"
                           value="<%= _v('gst_number') %>" placeholder="24ABCDE1234F1Z5" maxlength="30">
                </div>
                <div class="form-group">
                    <label class="form-label" for="sup-pan">PAN Number</label>
                    <input type="text" class="form-control text-uppercase" id="sup-pan" name="pan_number"
                           value="<%= _v('pan_number') %>" placeholder="ABCDE1234F" maxlength="20">
                </div>
            </div>
        </div><!-- /#gst -->

        <!-- ════ Other Details ════ -->
        <div class="tab-pane fade" id="other" role="tabpanel" aria-labelledby="other-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="sup-opening">Opening Balance (Payable)</label>
                    <div class="input-affix">
                        <input type="number" class="form-control has-suffix" id="sup-opening" name="opening_balance"
                               value="<%= _v('opening_balance') %>" placeholder="0" min="0" step="1">
                        <span class="affix affix--suffix">₹</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="sup-terms">Payment Terms</label>
                    <select class="form-select" id="sup-terms" name="payment_terms">
                        <%- _selOpts('Select terms', _terms, _v('payment_terms')) %>
                    </select>
                </div>
            </div>
        </div><!-- /#other -->

        <!-- ════ Custom Fields (dynamic key/value editor) ════ -->
        <div class="tab-pane fade" id="custom" role="tabpanel" aria-labelledby="custom-tab">
            <%- include('../partials/custom-fields', { cf: _cf, noun: 'supplier' }) %>
        </div><!-- /#custom -->

    </div><!-- /.tab-content -->

    <div class="form-card-footer">
        <a class="btn btn-light" href="/suppliers">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-floppy-disk me-1"></i><%= _isEdit ? 'Update' : 'Save' %> Supplier
        </button>
    </div>

</form>
