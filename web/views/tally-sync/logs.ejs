<%
/* ─────────────────────────────────────────────────────────────
 * views/tally-sync/logs.ejs — TALLY SYNC · Sync Logs.
 * Route: GET /sync-logs  ·  activeMenu: 'sync-logs'.
 *
 * Full audit trail of every push/pull between the cloud and Tally.
 *
 * Expected locals (routes/web.js → res.render):
 *   logRows         [ rows ]   — table body
 *   logsTotal       number     — pagination total
 *   page, perPage   numbers
 *   syncModuleNames / syncDirections / syncLogStatuses — filter options
 * ─────────────────────────────────────────────────────────── */

var _rows     = (typeof logRows !== 'undefined' && logRows) ? logRows : [];
var _total    = (typeof logsTotal !== 'undefined') ? logsTotal : _rows.length;
var _page     = (typeof page !== 'undefined' && page) ? page : 1;
var _perPage  = (typeof perPage !== 'undefined' && perPage) ? perPage : 10;
var _modules  = (typeof syncModuleNames !== 'undefined' && syncModuleNames) ? syncModuleNames : [];
var _dirs     = (typeof syncDirections !== 'undefined' && syncDirections) ? syncDirections : [];
var _statuses = (typeof syncLogStatuses !== 'undefined' && syncLogStatuses) ? syncLogStatuses : [];
var _restartHelp = (typeof restartHelp !== 'undefined' && restartHelp) ? restartHelp : '';

// Failed rows on THIS page → the "Failure reasons & fixes" list. De-dupe by
// cause so a screenful of the same error collapses to one actionable card.
var _failed = _rows.filter(function (r) { return r.failed; });
var _seenCause = {};
var _fixes = [];
_failed.forEach(function (r) {
    var key = String(r.reason || '');
    if (_seenCause[key]) return;
    _seenCause[key] = true;
    _fixes.push({ module: r.module, reason: r.reason, fix: r.fix, raw: r.raw });
});

function _opts(all, list) {
    var out = [{ value: '', label: all }];
    (list || []).forEach(function (v) { out.push({ value: v, label: v }); });
    return out;
}

/* ── FilterCard config (5 fields) ───────────────────────────── */
var filterFields = [
    { type: 'text',   name: 'search',    label: 'Search',    placeholder: 'Record / message...',     colClass: 'filter-col-fifth' },
    { type: 'select', name: 'module',    label: 'Module',    options: _opts('All Modules', _modules), colClass: 'filter-col-fifth' },
    { type: 'select', name: 'direction', label: 'Direction', options: _opts('All', _dirs),            colClass: 'filter-col-fifth' },
    { type: 'select', name: 'status',    label: 'Status',    options: _opts('All Status', _statuses), colClass: 'filter-col-fifth' },
    { type: 'date',   name: 'date_from', label: 'Date From', value: '2024-05-01',                    colClass: 'filter-col-fifth' },
];

/* ── Table config ───────────────────────────────────────────── */
var tableColumns = [
    { key: 'module',    label: 'Module',    sortable: true, type: 'text' },
    { key: 'record',    label: 'Record',    sortable: true, type: 'text' },
    { key: 'direction', label: 'Direction', sortable: true, type: 'badge' },
    { key: 'status',    label: 'Status',    sortable: true, type: 'status' },
    { key: 'message',   label: 'Message',   sortable: false, type: 'text' },
    { key: 'time',      label: 'Time',      sortable: true, type: 'text' },
];

var sortOptions = ['Time', 'Module', 'Status'];
%>

<%- include('../partials/page-head', {
    title: 'Sync Logs',
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'Sync Logs' },
    ],
    actions: [
        { label: 'Export',       icon: 'fa-upload', variant: 'light' },
        { label: 'Retry Failed', icon: 'fa-arrow-rotate-left', gradient: true, id: 'logs-retry' },
    ],
}) %>

<form id="logs-filters-form" autocomplete="off" method="get" action="/sync-logs">
    <%- include('../partials/filter-card', {
        filterId: 'logs-filters',
        title: 'Advanced Filters',
        fields: filterFields,
        collapsed: false,
    }) %>
</form>

<div class="card">

    <div class="table-toolbar">
        <label class="toolbar-show mb-0">
            <span>Show</span>
            <select class="form-select form-select-sm" aria-label="Rows per page">
                <option value="10" selected>10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
            <span>entries</span>
        </label>

        <div class="toolbar-sort">
            <span>Sort By</span>
            <select class="form-select form-select-sm" aria-label="Sort by column">
                <% sortOptions.forEach(function (label) { %>
                    <option value="<%= label %>" <%= label === 'Time' ? 'selected' : '' %>><%= label %></option>
                <% }); %>
            </select>
            <button type="button" class="sort-dir-btn" title="Toggle sort direction" aria-label="Toggle sort direction">
                <i class="fa-solid fa-arrow-down-short-wide"></i>
            </button>
        </div>
    </div>

    <%- include('../partials/table', {
        tableId: 'sync-logs-table',
        columns: tableColumns,
        rows: _rows,
        selectable: true,
        showIndex: true,
        actions: ['view'],
    }) %>

    <%- include('../partials/pagination', {
        page: _page,
        perPage: _perPage,
        total: _total,
    }) %>

</div>

<!-- ── Common fixes / How to restart ──────────────────────────────────────
     Per-failure plain-language cause + fix (de-duped from the rows on this
     page) plus a fixed "how to restart the agent" note. Hidden entirely when
     nothing on the page failed. -->
<div class="card mt-3">
    <div class="card-body">
        <h6 class="mb-3">
            <i class="fa-solid fa-circle-question text-primary me-2"></i>Common fixes / How to restart
        </h6>

        <% if (_fixes.length) { %>
            <div class="sync-fixes">
                <% _fixes.forEach(function (f) { %>
                    <div class="sync-fix-item">
                        <div class="sync-fix-cause">
                            <i class="fa-solid fa-triangle-exclamation text-danger me-2"></i>
                            <strong><%= f.reason %></strong>
                            <% if (f.module) { %><span class="text-muted small ms-2">(<%= f.module %>)</span><% } %>
                        </div>
                        <div class="sync-fix-fix text-muted">
                            <i class="fa-solid fa-screwdriver-wrench me-2"></i><%= f.fix %>
                        </div>
                        <% if (f.raw && String(f.raw) !== String(f.reason)) { %>
                            <div class="sync-fix-raw small text-muted mt-1">
                                <i class="fa-regular fa-message me-2"></i>Tally said: <%= f.raw %>
                            </div>
                        <% } %>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <p class="text-muted mb-3">
                <i class="fa-solid fa-circle-check text-success me-2"></i>No failures on this page.
            </p>
        <% } %>

        <% if (_restartHelp) { %>
            <div class="alert alert-info d-flex align-items-start mb-0 mt-3" role="note">
                <i class="fa-solid fa-rotate-right me-2 mt-1"></i>
                <span><%= _restartHelp %></span>
            </div>
        <% } %>
    </div>
</div>

<style>
    .sync-fixes { display: grid; gap: .75rem; }
    .sync-fix-item { padding: .75rem 1rem; border: 1px solid var(--bs-border-color, #e5e7eb); border-radius: .5rem; background: #fafafa; }
    .sync-fix-cause { margin-bottom: .25rem; }
    .sync-fix-fix { font-size: .9rem; }
</style>

<style>
    @media (min-width: 992px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 20%; }
    }
    @media (min-width: 768px) and (max-width: 991.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 33.3333%; }
    }
    @media (min-width: 576px) and (max-width: 767.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 50%; }
    }
    @media (max-width: 575.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 100%; }
    }
</style>
