<%
/* ─────────────────────────────────────────────────────────────
 * views/purchase-invoices/list.ejs — TRANSACTIONS · Purchase Invoices.
 * Route: GET /purchase-invoices  ·  activeMenu: 'purchase-inv'.
 *
 * Buy-side mirror of the Sales Invoices list (same status workflow).
 *
 * Expected locals (routes/web.js → res.render):
 *   purchaseRows     [ rows ]   — table body
 *   purchasesTotal   number     — pagination total
 *   page, perPage    numbers
 *   supplierNames / locationNames / invoiceStatuses — filter options
 * ─────────────────────────────────────────────────────────── */

var _rows     = (typeof purchaseRows !== 'undefined' && purchaseRows) ? purchaseRows : [];
var _total    = (typeof purchasesTotal !== 'undefined') ? purchasesTotal : _rows.length;
var _page     = (typeof page !== 'undefined' && page) ? page : 1;
var _perPage  = (typeof perPage !== 'undefined' && perPage) ? perPage : 10;
var _sups     = (typeof supplierNames !== 'undefined' && supplierNames) ? supplierNames : [];
var _statuses = (typeof invoiceStatuses !== 'undefined' && invoiceStatuses) ? invoiceStatuses : [];

function _opts(all, list) {
    var out = [{ value: '', label: all }];
    (list || []).forEach(function (v) { out.push({ value: v, label: v }); });
    return out;
}

/* ── FilterCard config (5 fields) ───────────────────────────── */
var filterFields = [
    { type: 'text',   name: 'search',    label: 'Search',    placeholder: 'Bill no / supplier...',  colClass: 'filter-col-fifth' },
    { type: 'select', name: 'supplier',  label: 'Supplier',  options: _opts('All Suppliers', _sups), colClass: 'filter-col-fifth' },
    { type: 'select', name: 'status',    label: 'Status',    options: _opts('All Status', _statuses), colClass: 'filter-col-fifth' },
    { type: 'date',   name: 'date_from', label: 'Date From', value: '2024-05-01',                   colClass: 'filter-col-fifth' },
    { type: 'date',   name: 'date_to',   label: 'Date To',   value: '2024-05-31',                   colClass: 'filter-col-fifth' },
];

/* ── Table config ───────────────────────────────────────────── */
var tableColumns = [
    { key: 'bill_no',  label: 'Bill No',  sortable: true, type: 'text' },
    { key: 'date',     label: 'Date',     sortable: true, type: 'date' },
    { key: 'supplier', label: 'Supplier', sortable: true, type: 'text' },
    { key: 'location', label: 'Location', sortable: true, type: 'location' },
    { key: 'amount',   label: 'Taxable',  sortable: true, type: 'currency' },
    { key: 'gst',      label: 'GST',      sortable: true, type: 'currency' },
    { key: 'total',    label: 'Total',    sortable: true, type: 'currency' },
    { key: 'status',   label: 'Status',   sortable: true, type: 'status' },
];

var sortOptions = ['Date', 'Bill No', 'Supplier', 'Total', 'Status'];
%>

<%- include('../partials/page-head', {
    title: 'Purchase Invoices',
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'Purchase Invoices' },
    ],
    actions: [
        { label: 'Export',          icon: 'fa-upload', variant: 'light' },
        { label: 'Create Purchase', icon: 'fa-plus',   gradient: true, href: '/purchase-invoices/create' },
    ],
}) %>

<form id="purchase-filters-form" autocomplete="off" method="get" action="/purchase-invoices">
    <%- include('../partials/filter-card', {
        filterId: 'purchase-filters',
        title: 'Advanced Filters',
        fields: filterFields,
        collapsed: false,
    }) %>
</form>

<div class="card">

    <div class="table-toolbar">
        <label class="toolbar-show mb-0">
            <span>Show</span>
            <select class="form-select form-select-sm" aria-label="Rows per page">
                <option value="10" selected>10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
            <span>entries</span>
        </label>

        <div class="toolbar-sort">
            <span>Sort By</span>
            <select class="form-select form-select-sm" aria-label="Sort by column">
                <% sortOptions.forEach(function (label) { %>
                    <option value="<%= label %>" <%= label === 'Date' ? 'selected' : '' %>><%= label %></option>
                <% }); %>
            </select>
            <button type="button" class="sort-dir-btn" title="Toggle sort direction" aria-label="Toggle sort direction">
                <i class="fa-solid fa-arrow-down-short-wide"></i>
            </button>
        </div>
    </div>

    <%- include('../partials/table', {
        tableId: 'purchase-invoices-table',
        basePath: '/purchase-invoices',
        columns: tableColumns,
        rows: _rows,
        selectable: true,
        showIndex: true,
        actions: ['view', 'print', 'delete'],
    }) %>

    <%- include('../partials/pagination', {
        page: _page,
        perPage: _perPage,
        total: _total,
    }) %>

</div>

<style>
    @media (min-width: 992px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 20%; }
    }
    @media (min-width: 768px) and (max-width: 991.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 33.3333%; }
    }
    @media (min-width: 576px) and (max-width: 767.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 50%; }
    }
    @media (max-width: 575.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 100%; }
    }
</style>
