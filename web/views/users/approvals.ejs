<%
/* ─────────────────────────────────────────────────────────────
 * views/users/approvals.ejs — PLATFORM ADMIN · User Approvals.
 * Route: GET /user-approvals  ·  activeMenu: 'user-approvals'  ·  super-admin only.
 *
 * Cross-tenant list of users a company-admin created who are PENDING and
 * cannot sign in until the platform super-admin Approves (= provisions a
 * paid seat, capped by the license max_users) or Rejects them.
 *
 * Mirrors licenses/list.ejs: the table is rendered inline (NOT via
 * partials/table) because its row actions are POST forms; it reuses the
 * SAME .card / .table.data-table / .pill-status classes so it looks
 * identical to every other listing.
 *
 * Expected locals (routes/web.js → res.render):
 *   approvalRows   [ rows ]   — table body (already mapped for display)
 *   approvalsTotal number     — pagination total
 *   page, perPage  numbers
 * ─────────────────────────────────────────────────────────── */

var _rows    = (typeof approvalRows !== 'undefined' && approvalRows) ? approvalRows : [];
var _total   = (typeof approvalsTotal !== 'undefined') ? approvalsTotal : _rows.length;
var _page    = (typeof page !== 'undefined' && page) ? page : 1;
var _perPage = (typeof perPage !== 'undefined' && perPage) ? perPage : 10;
%>

<%- include('../partials/page-head', {
    title: 'User Approvals',
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'User Approvals' },
    ],
}) %>

<div class="card">

    <% if (!_rows.length) { %>
        <div class="data-table-empty text-center text-muted py-5">
            <i class="fa-regular fa-circle-check d-block mb-2 fs-3"></i>
            No users are waiting for approval.
        </div>
    <% } else { %>
    <div class="table-responsive data-table-wrap">
        <table class="table data-table align-middle mb-0" id="approvals-table">
            <thead>
                <tr>
                    <th class="data-table-idx">#</th>
                    <th class="text-start">Name</th>
                    <th class="text-start">Email</th>
                    <th class="text-start">Mobile</th>
                    <th class="text-start">Role</th>
                    <th class="text-start">Company</th>
                    <th class="text-start">License</th>
                    <th class="text-start">Seats</th>
                    <th class="text-start">Requested</th>
                    <th class="text-end data-table-actions-head">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% _rows.forEach(function (row, i) { %>
                    <tr>
                        <td class="data-table-idx text-muted"><%= i + 1 %></td>
                        <td class="text-start"><%= row.name %></td>
                        <td class="text-start"><%= row.email %></td>
                        <td class="text-start"><%= row.mobile || '—' %></td>
                        <td class="text-start"><span class="pill-badge"><%= row.role %></span></td>
                        <td class="text-start"><%= row.company %></td>
                        <td class="text-start"><%= row.license_holder %></td>
                        <td class="text-start">
                            <% if (row.seats_full) { %>
                                <span class="pill-status pill-status--warning" title="Seat limit reached for this license">
                                    <%= row.license_used_seats %> / <%= row.license_max_users %>
                                </span>
                            <% } else { %>
                                <%= row.license_used_seats %> / <%= row.license_max_users %>
                            <% } %>
                        </td>
                        <td class="text-start"><%= row.created_at %></td>
                        <td class="text-end data-table-actions">
                            <form method="post" action="/user-approvals/<%= row.id %>/approve" class="d-inline">
                                <button type="submit" class="btn btn-light btn-sm" title="Approve this user">
                                    <i class="fa-solid fa-circle-check me-1"></i>Approve
                                </button>
                            </form>
                            <form method="post" action="/user-approvals/<%= row.id %>/reject" class="d-inline"
                                  onsubmit="return confirm('Reject this user request? They will not be able to sign in.');">
                                <button type="submit" class="btn btn-light btn-sm text-danger" title="Reject this user request">
                                    <i class="fa-solid fa-ban me-1"></i>Reject
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <%- include('../partials/pagination', {
        page: _page,
        perPage: _perPage,
        total: _total,
    }) %>
    <% } %>

</div>
