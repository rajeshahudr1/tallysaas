<%
/* ─────────────────────────────────────────────────────────────
 * views/auth/login.ejs — standalone sign-in page (rendered with
 * layout:false, so it is a full HTML document with no app chrome).
 * Posts to /login → AuthController.login → api /auth/login.
 *
 * Locals: error (string|null), email (prefill), next (redirect target).
 * ─────────────────────────────────────────────────────────── */
var _err   = (typeof error !== 'undefined') ? error : null;
var _email = (typeof email !== 'undefined' && email) ? email : '';
var _next  = (typeof next !== 'undefined' && next) ? next : '/';
%><!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Sign in · Tally Cloud Sync</title>
    <meta name="theme-color" content="#2563EB">
    <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" referrerpolicy="no-referrer">
    <link rel="stylesheet" href="/css/theme.css?v=3">
    <style>
        body { font-family: Inter, system-ui, sans-serif; min-height: 100vh; margin: 0;
            display: grid; place-items: center; padding: 24px;
            background: linear-gradient(135deg, #2563EB 0%, #6D28D9 100%); }
        .login-card { width: 100%; max-width: 410px; background: #fff; border-radius: 18px;
            box-shadow: 0 20px 60px rgba(16,24,40,.25); padding: 34px 32px; }
        .login-brand { display: flex; align-items: center; gap: 11px; margin-bottom: 22px; }
        .login-logo { width: 42px; height: 42px; border-radius: 11px; display: grid; place-items: center;
            background: linear-gradient(135deg, #2563EB, #6D28D9); color: #fff; font-size: 19px; }
        .login-brand-text { font-weight: 700; font-size: 18px; color: #111827; }
        .login-title { font-size: 21px; font-weight: 700; color: #111827; margin: 0 0 4px; }
        .login-sub { color: #6B7280; font-size: 13.5px; margin: 0 0 22px; }
        .login-card .form-label { font-weight: 600; font-size: 13px; color: #374151; }
        .login-card .form-control { padding: 11px 13px; border-radius: 10px; border-color: #E5E7EB; }
        .login-card .form-control:focus { border-color: #2563EB; box-shadow: 0 0 0 3px rgba(37,99,235,.14); }
        .login-btn { width: 100%; padding: 12px; border: 0; border-radius: 10px; color: #fff; font-weight: 600;
            background: linear-gradient(135deg, #2563EB, #6D28D9); }
        .login-hint { margin-top: 18px; font-size: 12.5px; color: #6B7280; text-align: center;
            background: #F8FAFC; border: 1px solid #E5E7EB; border-radius: 10px; padding: 10px; }
        .login-err { background: #FEE2E2; color: #B91C1C; border: 1px solid #FECACA; border-radius: 10px;
            padding: 10px 13px; font-size: 13px; margin-bottom: 16px; display: flex; gap: 8px; align-items: center; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-brand">
            <span class="login-logo"><i class="fa-solid fa-cloud"></i></span>
            <span class="login-brand-text">Tally Cloud Sync</span>
        </div>

        <h1 class="login-title">Welcome back</h1>
        <p class="login-sub">Sign in to your account to continue.</p>

        <% if (_err) { %>
            <div class="login-err"><i class="fa-solid fa-circle-exclamation"></i><span><%= _err %></span></div>
        <% } %>

        <form method="post" action="/login" autocomplete="on">
            <input type="hidden" name="next" value="<%= _next %>">
            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <input type="email" class="form-control" id="email" name="email"
                       value="<%= _email %>" placeholder="you@company.com" required autofocus>
            </div>
            <div class="mb-3">
                <label class="form-label" for="password">Password</label>
                <input type="password" class="form-control" id="password" name="password"
                       placeholder="••••••••" required>
            </div>
            <button type="submit" class="login-btn">
                <i class="fa-solid fa-right-to-bracket me-1"></i> Sign in
            </button>
        </form>

        <div class="login-hint">
            <strong>Demo:</strong> admin@tallysaas.test &nbsp;/&nbsp; Admin@123
        </div>
    </div>
</body>
</html>
