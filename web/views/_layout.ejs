<%
/* ─────────────────────────────────────────────────────────────
 * _layout.ejs — the single HTML shell wrapping every page (spec §3).
 *
 * Renders: <head> (CDNs + Inter + manifest + theme.css) → desktop
 * fixed sidebar + mobile offcanvas sidebar -> header -> page body ->
 * mobile bottom-nav -> scripts (Bootstrap bundle, Chart.js, app.js,
 * optional per-page `pageScript`, and PWA service-worker registration).
 *
 * Expected locals (defaults set in index.js so nothing ever crashes):
 *   title             string   — page title (→ "<title> · Tally Cloud Sync")
 *   activeMenu        string   — sidebar/bottom-nav active key
 *   user, company,    objects  — header identity (see data/mock.js)
 *   companies, notificationCount
 *   pageScript        string?  — extra <script> markup for this page only
 * ─────────────────────────────────────────────────────────── */
var _title      = (typeof title !== 'undefined' && title) ? title : 'Tally Cloud Sync';
var _activeMenu = (typeof activeMenu !== 'undefined') ? activeMenu : '';
%><!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <title><%= _title %> · Tally Cloud Sync</title>
    <meta name="theme-color" content="#2563EB">
    <meta name="description" content="Tally Cloud Sync — cloud accounting that syncs with Tally.">

    <!-- PWA -->
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
    <link rel="apple-touch-icon" href="/icons/icon-192.svg">

    <!-- Inter (Google Fonts) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 (CDN) — no SRI integrity (CDN hash drift was blocking the
         resource); fine for this app since it loads its own CSS/JS over HTTPS. -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome 6 (CDN) — integrity removed (the published SHA-512 no
         longer matched, so the browser BLOCKED the stylesheet and every icon
         disappeared). Loaded plainly over HTTPS instead. -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" referrerpolicy="no-referrer">

    <!-- App theme (single source of custom styling). ?v bust = force fresh
         CSS past any stale service-worker cache after an update. -->
    <link rel="stylesheet" href="/css/theme.css?v=3">
</head>
<body class="app">

    <!-- ── Desktop sidebar (fixed left) ───────────────────────── -->
    <aside class="sidebar d-none d-lg-flex" id="appSidebar">
        <%- include('partials/sidebar', { activeMenu: _activeMenu }) %>
    </aside>

    <!-- ── Mobile sidebar (offcanvas drawer) ──────────────────── -->
    <div class="offcanvas offcanvas-start sidebar-offcanvas" tabindex="-1" id="sidebarOffcanvas"
         aria-label="Navigation menu">
        <%- include('partials/sidebar', { activeMenu: _activeMenu }) %>
    </div>

    <!-- ── Main column (offset by sidebar on desktop) ─────────── -->
    <div class="app-main">

        <%- include('partials/header', {
            user, company, companies, notificationCount
        }) %>

        <main class="page">
            <% if (typeof flash !== 'undefined' && flash && flash.msg) { %>
                <div class="alert alert-<%= flash.type === 'error' ? 'danger' : (flash.type || 'success') %> alert-dismissible fade show flash-banner" role="alert">
                    <i class="fa-solid <%= flash.type === 'error' ? 'fa-circle-exclamation' : 'fa-circle-check' %> me-2"></i>
                    <%= flash.msg %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>
            <%- body %>
        </main>
    </div>

    <!-- ── Mobile bottom navigation ───────────────────────────── -->
    <%- include('partials/bottom-nav', { activeMenu: _activeMenu }) %>

    <!-- ── Custom row-action popups (wired in app.js — NOT browser dialogs) ── -->
    <!-- Delete confirmation -->
    <div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-body text-center p-4">
                    <div class="confirm-delete-icon mb-3"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <h5 class="mb-1">Delete this record?</h5>
                    <p class="text-muted mb-4" id="confirmDeleteText">This action cannot be undone.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-danger px-4" id="confirmDeleteBtn">
                            <i class="fa-regular fa-trash-can me-1"></i>Delete
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- View details -->
    <div class="modal fade" id="viewRecordModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="viewRecordTitle">Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <dl class="record-detail" id="viewRecordBody"></dl>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Scripts ────────────────────────────────────────────── -->
    <!-- Bootstrap 5 bundle (Popper included) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Chart.js (dashboard) -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <!-- App behaviours (sidebar/row-actions/filter/counters/PWA install/offline) -->
    <script src="/js/app.js?v=3" defer></script>

    <!-- Per-page script slot (e.g. dashboard.js). Guarded so a missing
         local never breaks the render. -->
    <%- (typeof pageScript !== 'undefined' && pageScript) ? pageScript : '' %>

    <!-- ── PWA service-worker registration ────────────────────── -->
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('/service-worker.js').catch(function (err) {
                    console.warn('SW registration failed:', err);
                });
            });
        }
    </script>
</body>
</html>
