<%
/* ─────────────────────────────────────────────────────────────
 * views/customers/form.ejs — Add / Edit Customer.
 * Routes: GET /customers/add · GET /customers/:id/edit.
 *
 * Every tab maps to REAL editable columns on the `customers` table —
 * the old "coming next phase" placeholders are gone and the Bank Details
 * tab (no backing columns) was removed. Synced Tally values pre-fill.
 *
 * Expected locals (routes/web.js → res.render):
 *   locationOptions / salesPersonOptions / customerGroupOptions — [{id,name}]
 *   record  — the row being edited (edit mode)  — optional
 * ─────────────────────────────────────────────────────────── */

var _locations      = (typeof locationOptions !== 'undefined' && locationOptions) ? locationOptions : [];
var _salesPersons   = (typeof salesPersonOptions !== 'undefined' && salesPersonOptions) ? salesPersonOptions : [];
var _customerGroups = (typeof customerGroupOptions !== 'undefined' && customerGroupOptions) ? customerGroupOptions : [];

var _rec    = (typeof record !== 'undefined' && record) ? record : null;
var _isEdit = !!_rec;
function _v(k){ return (_rec && _rec[k] != null) ? _rec[k] : ''; }

var formTabs = [
    { id: 'basic',   label: 'Basic Information', icon: 'fa-id-card',          active: true },
    { id: 'address', label: 'Address',           icon: 'fa-map-location-dot'               },
    { id: 'gst',     label: 'GST & Tax Details',  icon: 'fa-percent'                        },
    { id: 'other',   label: 'Other Details',      icon: 'fa-circle-info'                    },
    { id: 'custom',  label: 'Custom Fields',      icon: 'fa-table-cells'                    },
];

function _selOpts(placeholder, list, selectedId) {
    var html = '<option value=""' + (_isEdit ? '' : ' selected') + ' disabled hidden>' + placeholder + '</option>';
    (list || []).forEach(function (o) {
        var sel = (selectedId != null && selectedId !== '' && String(selectedId) === String(o.id)) ? ' selected' : '';
        html += '<option value="' + o.id + '"' + sel + '>' + o.name + '</option>';
    });
    return html;
}

/* Custom Fields bag → key/value rows. */
var _cf = {};
try { var _raw = _rec ? _rec.custom_fields : null; _cf = (typeof _raw === 'string') ? JSON.parse(_raw || '{}') : (_raw || {}); } catch (e) { _cf = {}; }

var headActions =
    '<a class="btn btn-light" href="/customers">' +
        '<i class="fa-solid fa-arrow-left me-1"></i>Back to Customers' +
    '</a>' +
    '<button type="submit" form="customer-form" class="btn btn-primary">' +
        '<i class="fa-solid fa-floppy-disk me-1"></i>' + (_isEdit ? 'Update' : 'Save') + ' Customer' +
    '</button>';
%>

<%- include('../partials/page-head', {
    title: (_isEdit ? 'Edit' : 'Add') + ' Customer',
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'Customers', href: '/customers' },
        { label: (_isEdit ? 'Edit' : 'Add') + ' Customer' },
    ],
    actions: headActions,
}) %>

<form id="customer-form" class="card form-card" method="post" action="<%= _isEdit ? '/customers/' + _rec.id : '/customers' %>" autocomplete="off" novalidate>

    <%- include('../partials/form-card', { tabs: formTabs }) %>

    <div class="tab-content form-card-body">

        <!-- ════ Basic Information ════ -->
        <div class="tab-pane fade show active" id="basic" role="tabpanel" aria-labelledby="basic-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="cust-name">Customer Name<span class="req">*</span></label>
                    <input type="text" class="form-control" id="cust-name" name="name"
                           placeholder="Enter customer name" value="<%= _v('name') %>" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="cust-mobile">Mobile Number</label>
                    <div class="input-affix">
                        <span class="affix affix--prefix"><i class="fa-solid fa-mobile-screen"></i></span>
                        <input type="tel" class="form-control" id="cust-mobile" name="mobile"
                               placeholder="98765 43210" value="<%= _v('mobile') %>" maxlength="30">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="cust-alt-mobile">Alternate Mobile</label>
                    <div class="input-affix">
                        <span class="affix affix--prefix"><i class="fa-solid fa-phone"></i></span>
                        <input type="tel" class="form-control" id="cust-alt-mobile" name="alternate_mobile"
                               placeholder="Optional" value="<%= _v('alternate_mobile') %>" maxlength="30">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="cust-group">Customer Group</label>
                    <select class="form-select" id="cust-group" name="customer_group_id">
                        <%- _selOpts('Select group', _customerGroups, _v('customer_group_id')) %>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="cust-email">Email</label>
                    <div class="input-affix">
                        <span class="affix affix--prefix"><i class="fa-solid fa-envelope"></i></span>
                        <input type="email" class="form-control" id="cust-email" name="email"
                               placeholder="name@company.com" value="<%= _v('email') %>">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="cust-location">Location<span class="req">*</span></label>
                    <select class="form-select" id="cust-location" name="location_id" required>
                        <%- _selOpts('Select location', _locations, _v('location_id')) %>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="cust-sales-person">Sales Person</label>
                    <select class="form-select" id="cust-sales-person" name="sales_person_id">
                        <%- _selOpts('Select sales person', _salesPersons, _v('sales_person_id')) %>
                    </select>
                </div>
            </div>

            <hr class="form-divider">

            <div class="row g-4 align-items-start">
                <div class="col-12 col-md-7">
                    <label class="form-label d-block">Status<span class="req">*</span></label>
                    <div class="status-radios">
                        <label class="status-radio is-active">
                            <input type="radio" name="status" value="Active" <%= (!_isEdit || String(_v('status')) === 'Active') ? 'checked' : '' %>>
                            <span>Active</span>
                        </label>
                        <label class="status-radio is-inactive">
                            <input type="radio" name="status" value="Inactive" <%= String(_v('status')) === 'Inactive' ? 'checked' : '' %>>
                            <span>Inactive</span>
                        </label>
                        <label class="status-radio is-blocked">
                            <input type="radio" name="status" value="Blocked" <%= String(_v('status')) === 'Blocked' ? 'checked' : '' %>>
                            <span>Blocked</span>
                        </label>
                    </div>
                </div>
                <div class="col-12 col-md-5">
                    <label class="form-label d-block">Is Tally Ledger</label>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch"
                               id="cust-tally-ledger" name="is_tally_ledger" <%= _isEdit ? (_v('is_tally_ledger') ? 'checked' : '') : 'checked' %>>
                        <label class="form-check-label" for="cust-tally-ledger">Create as Tally ledger</label>
                    </div>
                    <div class="form-hint">Syncs this customer to Tally as a ledger account.</div>
                </div>
            </div>
        </div><!-- /#basic -->

        <!-- ════ Address ════ -->
        <div class="tab-pane fade" id="address" role="tabpanel" aria-labelledby="address-tab">
            <div class="row g-4">
                <div class="col-12 col-md-6">
                    <label class="form-label" for="shipping-address">Shipping Address</label>
                    <textarea class="form-control" id="shipping-address" name="shipping_address"
                              rows="4" maxlength="2000" placeholder="Building, street, area, city, state, pincode…"><%= _v('shipping_address') %></textarea>
                </div>
                <div class="col-12 col-md-6">
                    <div class="d-flex align-items-center justify-content-between mb-1">
                        <label class="form-label mb-0" for="billing-address">Billing Address</label>
                        <label class="same-as-label" for="same-as-shipping">
                            <input class="form-check-input mt-0" type="checkbox" id="same-as-shipping"
                                   data-same-as-shipping data-source="shipping-address" data-target="billing-address">
                            Same as Shipping Address
                        </label>
                    </div>
                    <textarea class="form-control" id="billing-address" name="billing_address"
                              rows="4" maxlength="2000" placeholder="Building, street, area, city, state, pincode…"><%= _v('billing_address') %></textarea>
                </div>
            </div>
        </div><!-- /#address -->

        <!-- ════ GST & Tax Details ════ -->
        <div class="tab-pane fade" id="gst" role="tabpanel" aria-labelledby="gst-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="cust-gst">GST Number</label>
                    <input type="text" class="form-control text-uppercase" id="cust-gst" name="gst_number"
                           value="<%= _v('gst_number') %>" placeholder="24ABCDE1234F1Z5" maxlength="30">
                </div>
                <div class="form-group">
                    <label class="form-label" for="cust-pan">PAN Number</label>
                    <input type="text" class="form-control text-uppercase" id="cust-pan" name="pan_number"
                           value="<%= _v('pan_number') %>" placeholder="ABCDE1234F" maxlength="30">
                </div>
            </div>
        </div><!-- /#gst -->

        <!-- ════ Other Details ════ -->
        <div class="tab-pane fade" id="other" role="tabpanel" aria-labelledby="other-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="cust-credit-limit">Credit Limit</label>
                    <div class="input-affix">
                        <input type="number" class="form-control has-suffix" id="cust-credit-limit" name="credit_limit"
                               placeholder="0" value="<%= _v('credit_limit') %>" min="0" step="1">
                        <span class="affix affix--suffix">₹</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="cust-opening-balance">Opening Balance</label>
                    <div class="input-affix">
                        <input type="number" class="form-control has-suffix" id="cust-opening-balance" name="opening_balance"
                               placeholder="0" value="<%= _v('opening_balance') %>" min="0" step="1">
                        <span class="affix affix--suffix">₹</span>
                    </div>
                </div>
            </div>
            <hr class="form-divider">
            <div class="row g-4">
                <div class="col-12 col-md-6">
                    <label class="form-label" for="cust-notes">Notes</label>
                    <textarea class="form-control" id="cust-notes" name="notes"
                              rows="3" maxlength="2000" placeholder="Any notes about this customer…"><%= _v('notes') %></textarea>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label" for="cust-remarks">Internal Remarks</label>
                    <textarea class="form-control" id="cust-remarks" name="internal_remarks"
                              rows="3" maxlength="2000" placeholder="Notes for your team…"><%= _v('internal_remarks') %></textarea>
                    <div class="form-hint"><i class="fa-solid fa-lock me-1"></i>Visible to your team only</div>
                </div>
            </div>
        </div><!-- /#other -->

        <!-- ════ Custom Fields (dynamic key/value editor) ════ -->
        <div class="tab-pane fade" id="custom" role="tabpanel" aria-labelledby="custom-tab">
            <%- include('../partials/custom-fields', { cf: _cf, noun: 'customer' }) %>
        </div><!-- /#custom -->

    </div><!-- /.tab-content -->

    <div class="form-card-footer">
        <a class="btn btn-light" href="/customers">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-floppy-disk me-1"></i><%= _isEdit ? 'Update' : 'Save' %> Customer
        </button>
    </div>

</form>
