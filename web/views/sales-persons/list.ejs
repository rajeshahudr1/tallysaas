<%
/* ─────────────────────────────────────────────────────────────
 * views/sales-persons/list.ejs — MASTERS · Sales Persons listing.
 * Route: GET /sales-persons  ·  activeMenu: 'sales'.
 *
 * Highlights the SalesPerson↔Location mapping: the "Assigned
 * Locations" column uses the table's `locations` (plural) type to
 * render an ARRAY of location names as multiple coloured pills.
 *
 * Expected locals (routes/web.js → res.render):
 *   salesPersonRows    [ rows ]  — table body (each has locations:[])
 *   salesPersonsTotal  number    — pagination total
 *   page, perPage      numbers
 *   locationNames      [ … ]     — Location filter options
 * ─────────────────────────────────────────────────────────── */

var _rows    = (typeof salesPersonRows !== 'undefined' && salesPersonRows) ? salesPersonRows : [];
var _total   = (typeof salesPersonsTotal !== 'undefined') ? salesPersonsTotal : _rows.length;
var _page    = (typeof page !== 'undefined' && page) ? page : 1;
var _perPage = (typeof perPage !== 'undefined' && perPage) ? perPage : 10;
var _locs    = (typeof locationNames !== 'undefined' && locationNames) ? locationNames : [];

function _opts(all, list) {
    var out = [{ value: '', label: all }];
    (list || []).forEach(function (v) { out.push({ value: v, label: v }); });
    return out;
}

/* ── FilterCard config (5 fields) ───────────────────────────── */
var filterFields = [
    { type: 'text',   name: 'search',       label: 'Search',           placeholder: 'Search by name, code, mobile...', colClass: 'filter-col-fifth' },
    { type: 'select', name: 'location',     label: 'Assigned Location', options: _opts('All Locations', _locs),         colClass: 'filter-col-fifth' },
    { type: 'select', name: 'status',       label: 'Status',           options: _opts('All Status', ['Active', 'Inactive', 'Blocked']), colClass: 'filter-col-fifth' },
    { type: 'date',   name: 'created_from', label: 'Created From',      value: '2024-01-01',                            colClass: 'filter-col-fifth' },
    { type: 'date',   name: 'created_to',   label: 'Created To',        value: '2024-12-31',                            colClass: 'filter-col-fifth' },
];

/* ── Table config ───────────────────────────────────────────── */
var tableColumns = [
    { key: 'name',          label: 'Name',              sortable: true, type: 'text' },
    { key: 'employee_code', label: 'Emp. Code',         sortable: true, type: 'badge' },
    { key: 'mobile',        label: 'Mobile',            sortable: true, type: 'text' },
    { key: 'email',         label: 'Email',             sortable: true, type: 'text' },
    { key: 'locations',     label: 'Assigned Locations', sortable: false, type: 'locations' },
    { key: 'customers',     label: 'Customers',         sortable: true, type: 'text', align: 'center' },
    { key: 'status',        label: 'Status',            sortable: true, type: 'status' },
    { key: 'created_at',    label: 'Created At',        sortable: true, type: 'date' },
];

var sortOptions = ['Created At', 'Name', 'Customers', 'Status'];
%>

<%- include('../partials/page-head', {
    title: 'Sales Persons',
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'Sales Persons' },
    ],
    actions: [
        { label: 'Export',           icon: 'fa-upload', variant: 'light' },
        { label: 'Add Sales Person', icon: 'fa-plus',   gradient: true, href: '/sales-persons/add' },
    ],
}) %>

<form id="sp-filters-form" autocomplete="off" method="get" action="/sales-persons">
    <%- include('../partials/filter-card', {
        filterId: 'sp-filters',
        title: 'Advanced Filters',
        fields: filterFields,
        collapsed: false,
    }) %>
</form>

<div class="card">

    <div class="table-toolbar">
        <label class="toolbar-show mb-0">
            <span>Show</span>
            <select class="form-select form-select-sm" aria-label="Rows per page">
                <option value="10" selected>10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
            <span>entries</span>
        </label>

        <div class="toolbar-sort">
            <span>Sort By</span>
            <select class="form-select form-select-sm" aria-label="Sort by column">
                <% sortOptions.forEach(function (label) { %>
                    <option value="<%= label %>" <%= label === 'Created At' ? 'selected' : '' %>><%= label %></option>
                <% }); %>
            </select>
            <button type="button" class="sort-dir-btn" title="Toggle sort direction" aria-label="Toggle sort direction">
                <i class="fa-solid fa-arrow-down-short-wide"></i>
            </button>
        </div>
    </div>

    <%- include('../partials/table', {
        tableId: 'sales-persons-table',
        basePath: '/sales-persons',
        editable: true,
        sortKeys: ['name', 'status', 'created_at'],
        columns: tableColumns,
        rows: _rows,
        selectable: true,
        showIndex: true,
        actions: ['view', 'edit', 'delete'],
    }) %>

    <%- include('../partials/pagination', {
        page: _page,
        perPage: _perPage,
        total: _total,
    }) %>

</div>

<style>
    @media (min-width: 992px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 20%; }
    }
    @media (min-width: 768px) and (max-width: 991.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 33.3333%; }
    }
    @media (min-width: 576px) and (max-width: 767.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 50%; }
    }
    @media (max-width: 575.98px) {
        .filter-grid > .filter-col-fifth { flex: 0 0 auto; width: 100%; }
    }
</style>
