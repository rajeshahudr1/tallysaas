<%
/* ─────────────────────────────────────────────────────────────
 * views/sales-invoices/create.ejs — TRANSACTIONS · Create Invoice.
 * Route: GET /sales-invoices/create  ·  activeMenu: 'sales-inv'.
 *
 * Three stacked cards inside one <form id="invoice-form">:
 *   1. Invoice Details  — customer / no / date / location / sales person.
 *   2. Line Items       — a <template>-driven editable grid; /js/invoice.js
 *                         clones rows, auto-fills HSN/Unit/Rate/GST from the
 *                         picked product, and live-computes Taxable/GST/Amount.
 *   3. Footer           — notes (left) + the Totals panel (right) + actions.
 *
 * The page-head Save buttons sit OUTSIDE the cards but submit the form via
 * form="invoice-form". Visual only in Phase 1 (no real submit).
 *
 * Expected locals (routes/web.js → res.render):
 *   customerNames / locationNames / salesPersons — header selects
 *   invoiceProducts [{name,hsn,unit,rate,gst}]   — line-item picker
 *   nextInvoiceNo   string                        — read-only invoice no.
 * ─────────────────────────────────────────────────────────── */

/* FK option sources are now [{id,name}] from the api (selects submit
 * real foreign keys); products carry id + line-item defaults. */
var _custs    = (typeof customerOptions !== 'undefined' && customerOptions) ? customerOptions : [];
var _locs     = (typeof locationOptions !== 'undefined' && locationOptions) ? locationOptions : [];
var _sps      = (typeof salesPersonOptions !== 'undefined' && salesPersonOptions) ? salesPersonOptions : [];
var _products = (typeof invoiceProducts !== 'undefined' && invoiceProducts) ? invoiceProducts : [];
var _invNo    = (typeof nextInvoiceNo !== 'undefined' && nextInvoiceNo) ? nextInvoiceNo : '';

/* FK <select> options — value = id. */
function _selOpts(placeholder, list) {
    var html = '<option value="" selected disabled hidden>' + placeholder + '</option>';
    (list || []).forEach(function (o) { html += '<option value="' + o.id + '">' + o.name + '</option>'; });
    return html;
}

/* Product <option>s: value = product id; data-* feed the line-item
 * engine (auto-fills HSN/unit/rate/GST when a product is chosen). */
var _productOptions = '<option value="" selected>Select product</option>';
_products.forEach(function (p) {
    _productOptions +=
        '<option value="' + p.id + '"' +
        ' data-hsn="'  + (p.hsn || '')  + '"' +
        ' data-unit="' + (p.unit || '') + '"' +
        ' data-rate="' + (p.rate || 0)  + '"' +
        ' data-gst="'  + (p.gst || 0)   + '">' + p.name + '</option>';
});

var headActions =
    '<a class="btn btn-light" href="/sales-invoices">' +
        '<i class="fa-solid fa-arrow-left me-1"></i>Back to Invoices' +
    '</a>' +
    '<div class="btn-group">' +
        '<button type="submit" form="invoice-form" class="btn btn-primary">' +
            '<i class="fa-solid fa-cloud-arrow-up me-1"></i>Save &amp; Send to Tally' +
        '</button>' +
        '<button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" ' +
                'data-bs-toggle="dropdown" aria-expanded="false">' +
            '<span class="visually-hidden">Toggle save options</span>' +
        '</button>' +
        '<ul class="dropdown-menu dropdown-menu-end">' +
            '<li><button type="submit" form="invoice-form" class="dropdown-item">' +
                '<i class="fa-regular fa-floppy-disk me-2 text-muted"></i>Save as Draft</button></li>' +
            '<li><button type="submit" form="invoice-form" class="dropdown-item">' +
                '<i class="fa-solid fa-print me-2 text-muted"></i>Save &amp; Print</button></li>' +
        '</ul>' +
    '</div>';
%>

<%- include('../partials/page-head', {
    title: 'Create Invoice',
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'Sales Invoices', href: '/sales-invoices' },
        { label: 'Create Invoice' },
    ],
    actions: headActions,
}) %>

<form id="invoice-form" method="post" action="/sales-invoices" autocomplete="off" novalidate>

    <!-- Line items are serialised to JSON here by /js/invoice.js on submit. -->
    <input type="hidden" name="items_json" id="items-json">

    <!-- ════ CARD 1 — Invoice Details ════ -->
    <div class="card mb-3">
        <div class="inv-section-head">
            <h2 class="inv-section-title"><i class="fa-solid fa-file-invoice me-2 text-primary"></i>Invoice Details</h2>
            <span class="pill-status pill-status--warning">Pending Tally</span>
        </div>
        <div class="inv-body">
            <div class="form-grid">

                <div class="form-group">
                    <label class="form-label" for="inv-customer">Customer<span class="req">*</span></label>
                    <select class="form-select" id="inv-customer" name="customer_id" required>
                        <%- _selOpts('Select customer', _custs) %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label" for="inv-no">Invoice No</label>
                    <input type="text" class="form-control" id="inv-no" name="invoice_no"
                           value="<%= _invNo %>" readonly>
                </div>

                <div class="form-group">
                    <label class="form-label" for="inv-date">Invoice Date<span class="req">*</span></label>
                    <input type="date" class="form-control" id="inv-date" name="invoice_date" value="2024-05-21" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="inv-location">Location</label>
                    <select class="form-select" id="inv-location" name="location_id">
                        <%- _selOpts('Select location', _locs) %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label" for="inv-sp">Sales Person</label>
                    <select class="form-select" id="inv-sp" name="sales_person_id">
                        <%- _selOpts('Select sales person', _sps) %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label" for="inv-due">Due Date</label>
                    <input type="date" class="form-control" id="inv-due" name="due_date" value="2024-06-20">
                </div>

            </div>
        </div>
    </div>

    <!-- ════ CARD 2 — Line Items ════ -->
    <div class="card mb-3">
        <div class="inv-section-head">
            <h2 class="inv-section-title"><i class="fa-solid fa-list me-2 text-primary"></i>Line Items</h2>
            <span class="form-hint mb-0" id="inv-itemcount">0 item(s)</span>
        </div>

        <div class="li-table-wrap">
            <table class="li-table">
                <thead>
                    <tr>
                        <th class="li-idx">#</th>
                        <th>Product</th>
                        <th>HSN</th>
                        <th class="num">Qty</th>
                        <th>Unit</th>
                        <th class="num">Rate (₹)</th>
                        <th class="num">Disc %</th>
                        <th class="num">Taxable (₹)</th>
                        <th class="num">GST %</th>
                        <th class="num">GST Amt (₹)</th>
                        <th class="num">Amount (₹)</th>
                        <th class="center"></th>
                    </tr>
                </thead>
                <!-- Rows are injected by /js/invoice.js from the template below. -->
                <tbody id="li-body"></tbody>
            </table>
        </div>

        <div class="inv-body pt-0">
            <button type="button" class="li-addrow" id="li-add-row">
                <i class="fa-solid fa-plus"></i> Add Row
            </button>
        </div>

        <!-- ════ Footer — Notes (left) + Totals (right) ════ -->
        <div class="inv-foot">
            <div>
                <label class="form-label" for="inv-notes">Notes / Terms</label>
                <textarea class="form-control" id="inv-notes" name="notes" rows="5"
                          maxlength="500" placeholder="Payment terms, delivery notes, bank details…"></textarea>
            </div>

            <div class="inv-totals">
                <div class="inv-total-row">
                    <span class="lbl">Subtotal</span><span class="val" id="inv-subtotal">₹0.00</span>
                </div>
                <div class="inv-total-row">
                    <span class="lbl">Discount</span><span class="val" id="inv-discount">− ₹0.00</span>
                </div>
                <div class="inv-total-row">
                    <span class="lbl">Taxable Value</span><span class="val" id="inv-taxable">₹0.00</span>
                </div>
                <div class="inv-total-row">
                    <span class="lbl">CGST</span><span class="val" id="inv-cgst">₹0.00</span>
                </div>
                <div class="inv-total-row">
                    <span class="lbl">SGST</span><span class="val" id="inv-sgst">₹0.00</span>
                </div>
                <div class="inv-total-row">
                    <span class="lbl">Round Off</span><span class="val" id="inv-roundoff">+ ₹0.00</span>
                </div>
                <div class="inv-total-row grand">
                    <span class="lbl">Grand Total</span><span class="val" id="inv-grand">₹0.00</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ════ Footer actions ════ -->
    <div class="card">
        <div class="form-card-footer" style="border-top:0; background:#fff;">
            <a class="btn btn-light" href="/sales-invoices">Cancel</a>
            <button type="submit" class="btn btn-light">
                <i class="fa-regular fa-floppy-disk me-1"></i>Save as Draft
            </button>
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-cloud-arrow-up me-1"></i>Save &amp; Send to Tally
            </button>
        </div>
    </div>

</form>

<!-- ── Line-item row template (cloned by /js/invoice.js) ─────────── -->
<template id="li-row-tpl">
    <tr class="li-row">
        <td class="li-idx"></td>
        <td><select class="li-product"><%- _productOptions %></select></td>
        <td><input type="text" class="li-hsn" readonly placeholder="—"></td>
        <td><input type="number" class="li-qty li-num" min="0" step="1" value="1"></td>
        <td><input type="text" class="li-unit" readonly placeholder="—"></td>
        <td><input type="number" class="li-rate li-num" min="0" step="0.01" value="0"></td>
        <td><input type="number" class="li-disc li-num" min="0" max="100" step="0.01" value="0"></td>
        <td><span class="li-taxable li-cell-calc">₹0.00</span></td>
        <td><input type="number" class="li-gst li-num" min="0" step="0.01" value="0"></td>
        <td><span class="li-gstamt li-cell-calc">₹0.00</span></td>
        <td><span class="li-amount li-cell-calc">₹0.00</span></td>
        <td class="center">
            <button type="button" class="li-remove" title="Remove row" aria-label="Remove row">
                <i class="fa-regular fa-trash-can"></i>
            </button>
        </td>
    </tr>
</template>
