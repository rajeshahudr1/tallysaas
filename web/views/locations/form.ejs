<%
/* ─────────────────────────────────────────────────────────────
 * views/locations/form.ejs — MASTERS · Add / Edit Location.
 * Routes: GET /locations/add (create) · GET /locations/:id/edit (edit).
 *
 * Every tab maps to a REAL editable column on the `locations` table
 * (name, code, city, state, pincode, mobile, manager, status,
 * is_tally_godown, custom_fields). Fields with no backing column
 * (email, notes, free-text address) were removed; the old "coming next
 * phase" placeholder tabs are gone — each tab now holds real inputs.
 *
 * Expected locals (routes/web.js → res.render):
 *   states        [ 'Gujarat', … ]      — State select options
 *   salesPersons  [ 'Rajesh Kumar', … ] — Manager (in-charge) options
 *   record        the row being edited (edit mode)      — optional
 * ─────────────────────────────────────────────────────────── */

var _rec    = (typeof record !== 'undefined' && record) ? record : null;
var _isEdit = !!_rec;
function _v(k){ return (_rec && _rec[k] != null) ? _rec[k] : ''; }   // scalar prefill helper

var _states       = (typeof states !== 'undefined' && states) ? states : [];
var _salesPersons = (typeof salesPersons !== 'undefined' && salesPersons) ? salesPersons : [];

var formTabs = [
    { id: 'basic',   label: 'Basic Information', icon: 'fa-id-card',          active: true },
    { id: 'address', label: 'Address',           icon: 'fa-map-location-dot'               },
    { id: 'contact', label: 'Contact & Manager', icon: 'fa-headset'                        },
    { id: 'custom',  label: 'Custom Fields',     icon: 'fa-table-cells'                    },
];

function _selOpts(placeholder, list, selVal) {
    var phSel = (selVal == null || String(selVal) === '') ? ' selected' : '';
    var html = '<option value=""' + phSel + ' disabled hidden>' + placeholder + '</option>';
    (list || []).forEach(function (v) {
        var sel = (String(selVal) === String(v)) ? ' selected' : '';
        html += '<option value="' + v + '"' + sel + '>' + v + '</option>';
    });
    return html;
}

/* Custom Fields bag → key/value rows. */
var _cf = {};
try { var _raw = _rec ? _rec.custom_fields : null; _cf = (typeof _raw === 'string') ? JSON.parse(_raw || '{}') : (_raw || {}); } catch (e) { _cf = {}; }
var _cfKeys = Object.keys(_cf);

var headActions =
    '<a class="btn btn-light" href="/locations">' +
        '<i class="fa-solid fa-arrow-left me-1"></i>Back to Locations' +
    '</a>' +
    '<button type="submit" form="location-form" class="btn btn-primary">' +
        '<i class="fa-solid fa-floppy-disk me-1"></i>' + (_isEdit ? 'Update' : 'Save') + ' Location' +
    '</button>';
%>

<%- include('../partials/page-head', {
    title: (_isEdit ? 'Edit' : 'Add') + ' Location',
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'Locations', href: '/locations' },
        { label: (_isEdit ? 'Edit' : 'Add') + ' Location' },
    ],
    actions: headActions,
}) %>

<form id="location-form" class="card form-card" method="post" action="<%= _isEdit ? '/locations/' + _rec.id : '/locations' %>" autocomplete="off" novalidate>

    <%- include('../partials/form-card', { tabs: formTabs }) %>

    <div class="tab-content form-card-body">

        <!-- ════ Basic Information ════ -->
        <div class="tab-pane fade show active" id="basic" role="tabpanel" aria-labelledby="basic-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="loc-name">Location Name<span class="req">*</span></label>
                    <input type="text" class="form-control" id="loc-name" name="name"
                           placeholder="e.g. Ahmedabad" value="<%= _v('name') %>" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="loc-code">Location Code</label>
                    <input type="text" class="form-control text-uppercase" id="loc-code" name="code"
                           placeholder="e.g. AHM" maxlength="50" value="<%= _v('code') %>">
                </div>
            </div>

            <hr class="form-divider">

            <div class="row g-4 align-items-start">
                <div class="col-12 col-md-6">
                    <label class="form-label d-block">Status<span class="req">*</span></label>
                    <div class="status-radios">
                        <label class="status-radio is-active">
                            <input type="radio" name="status" value="Active" <%= _isEdit ? (String(_v('status')) === 'Active' ? 'checked' : '') : 'checked' %>>
                            <span>Active</span>
                        </label>
                        <label class="status-radio is-inactive">
                            <input type="radio" name="status" value="Inactive" <%= String(_v('status')) === 'Inactive' ? 'checked' : '' %>>
                            <span>Inactive</span>
                        </label>
                        <label class="status-radio is-blocked">
                            <input type="radio" name="status" value="Blocked" <%= String(_v('status')) === 'Blocked' ? 'checked' : '' %>>
                            <span>Blocked</span>
                        </label>
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label d-block">Is Tally Godown</label>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch"
                               id="loc-tally-godown" name="is_tally_godown" <%= _isEdit ? (_v('is_tally_godown') ? 'checked' : '') : 'checked' %>>
                        <label class="form-check-label" for="loc-tally-godown">Map as Tally godown</label>
                    </div>
                    <div class="form-hint">Syncs this location to Tally as a godown for location-wise stock.</div>
                </div>
            </div>
        </div><!-- /#basic -->

        <!-- ════ Address ════ -->
        <div class="tab-pane fade" id="address" role="tabpanel" aria-labelledby="address-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="loc-city">City</label>
                    <input type="text" class="form-control" id="loc-city" name="city"
                           placeholder="Enter city" value="<%= _v('city') %>">
                </div>
                <div class="form-group">
                    <label class="form-label" for="loc-state">State</label>
                    <select class="form-select" id="loc-state" name="state">
                        <%- _selOpts('Select state', _states, _v('state')) %>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="loc-pincode">Pincode</label>
                    <input type="text" class="form-control" id="loc-pincode" name="pincode"
                           placeholder="380001" inputmode="numeric" maxlength="12" value="<%= _v('pincode') %>">
                </div>
            </div>
        </div><!-- /#address -->

        <!-- ════ Contact & Manager ════ -->
        <div class="tab-pane fade" id="contact" role="tabpanel" aria-labelledby="contact-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="loc-mobile">Mobile Number</label>
                    <div class="input-affix">
                        <span class="affix affix--prefix"><i class="fa-solid fa-mobile-screen"></i></span>
                        <input type="tel" class="form-control" id="loc-mobile" name="mobile"
                               placeholder="98765 43210" maxlength="30" value="<%= _v('mobile') %>">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="loc-manager">Manager / In-charge</label>
                    <select class="form-select" id="loc-manager" name="manager">
                        <%- _selOpts('Select manager', _salesPersons, _v('manager')) %>
                    </select>
                </div>
            </div>
        </div><!-- /#contact -->

        <!-- ════ Custom Fields (dynamic key/value editor) ════ -->
        <div class="tab-pane fade" id="custom" role="tabpanel" aria-labelledby="custom-tab">
            <%- include('../partials/custom-fields', { cf: _cf, noun: 'location' }) %>
        </div><!-- /#custom -->

    </div><!-- /.tab-content -->

    <div class="form-card-footer">
        <a class="btn btn-light" href="/locations">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-floppy-disk me-1"></i><%= _isEdit ? 'Update' : 'Save' %> Location
        </button>
    </div>

</form>
