<%
/* ─────────────────────────────────────────────────────────────
 * views/roles/list.ejs — SETTINGS · Roles (license-admin / tenant).
 * Route: GET /roles-admin  ·  activeMenu: 'roles'  ·  company-admin only.
 *
 * Lists the license's roles: built-in SYSTEM roles (read-only) plus this
 * license's CUSTOM roles (editable). Custom rows get Edit + Delete (POST,
 * confirmed via the shared confirm-delete modal). A "New Role" button heads
 * to the create form.
 *
 * Rendered inline (NOT via partials/table) because the row actions are POST
 * forms / links, but reuses the SAME .card / .table.data-table / .pill-status
 * classes so it looks identical to every other listing.
 *
 * Expected locals (routes/web.js → res.render):
 *   roleRows  [ { id, name, slug, is_system, editable, user_count } ]
 * ─────────────────────────────────────────────────────────── */

var _rows = (typeof roleRows !== 'undefined' && roleRows) ? roleRows : [];
%>

<%- include('../partials/page-head', {
    title: 'Roles',
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'Roles' },
    ],
    actions: [
        { label: 'New Role', icon: 'fa-plus', gradient: true, href: '/roles-admin/new' },
    ],
}) %>

<div class="card">

    <div class="table-responsive data-table-wrap">
        <table class="table data-table align-middle mb-0" id="roles-table">
            <thead>
                <tr>
                    <th class="data-table-idx">#</th>
                    <th class="text-start">Name</th>
                    <th class="text-start">Type</th>
                    <th class="text-start">Users</th>
                    <th class="text-end data-table-actions-head">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (!_rows.length) { %>
                    <tr>
                        <td class="data-table-empty text-center text-muted py-5" colspan="5">
                            <i class="fa-regular fa-folder-open d-block mb-2 fs-3"></i>
                            No roles found.
                        </td>
                    </tr>
                <% } %>
                <% _rows.forEach(function (row, i) { %>
                    <tr>
                        <td class="data-table-idx text-muted"><%= i + 1 %></td>
                        <td class="text-start"><%= row.name %></td>
                        <td class="text-start">
                            <% if (row.is_system) { %>
                                <span class="pill-status pill-status--info">System</span>
                            <% } else { %>
                                <span class="pill-status pill-status--success">Custom</span>
                            <% } %>
                        </td>
                        <td class="text-start"><%= row.user_count != null ? row.user_count : 0 %></td>
                        <td class="text-end data-table-actions">
                            <% if (row.editable) { %>
                                <a href="/roles-admin/<%= row.id %>" class="btn btn-light btn-sm" title="Edit role">
                                    <i class="fa-solid fa-pen me-1"></i>Edit
                                </a>
                                <button type="button" class="btn btn-light btn-sm" title="Delete role"
                                        data-row-delete
                                        data-delete-url="/roles-admin/<%= row.id %>"
                                        data-delete-label="the role &quot;<%= row.name %>&quot;">
                                    <i class="fa-regular fa-trash-can me-1"></i>Delete
                                </button>
                            <% } else { %>
                                <a href="/roles-admin/<%= row.id %>" class="btn btn-light btn-sm" title="View role permissions">
                                    <i class="fa-solid fa-eye me-1"></i>View
                                </a>
                            <% } %>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

</div>
