<%
/* ─────────────────────────────────────────────────────────────
 * views/roles/form.ejs — SETTINGS · Create / Edit custom Role.
 * Routes: GET /roles-admin/new  +  GET /roles-admin/:id  ·  activeMenu: 'roles'.
 *
 * A Name field + a module × action permission grid BUILT FROM the license's
 * entitlements (GET /account/roles/available-permissions): rows = entitled
 * modules, columns = ONLY that module's entitled actions. Checkboxes are named
 * `perm` with value `<module>.<action>` (so Express parses them into an array).
 * On edit the grid is pre-checked from the role's current permissions.
 *
 * System (non-editable) roles render READ-ONLY — the inputs are disabled and
 * the save footer is hidden, so the screen doubles as a "View" of a built-in
 * role's effective permissions.
 *
 * If the license has NO entitled modules a friendly note is shown instead of
 * an empty grid.
 *
 * Reuses the SAME .card / .rbac-matrix / form / theme classes as the rest of
 * the app (no bespoke CSS).
 *
 * Expected locals (routes/web.js → res.render):
 *   mode        'create' | 'edit'
 *   role        { id, name, slug, is_system, editable, permissions:[ '<m>.<a>' ] }  (edit only)
 *   modules     [ { key, label, actions:[ 'view', ... ] } ]   (entitled only)
 *   permsSet    { '<module>.<action>': true }                  (pre-checked set)
 *   editable    bool  — false ⇒ read-only view
 * ─────────────────────────────────────────────────────────── */

var _mode     = (typeof mode !== 'undefined' && mode) ? mode : 'create';
var _role     = (typeof role !== 'undefined' && role) ? role : {};
var _modules  = (typeof modules !== 'undefined' && modules) ? modules : [];
var _permsSet = (typeof permsSet !== 'undefined' && permsSet) ? permsSet : {};
var _editable = (typeof editable !== 'undefined') ? !!editable : (_mode === 'create');

var _isEdit   = _mode === 'edit';
var _name     = _role.name || '';
var _action   = _isEdit ? ('/roles-admin/' + _role.id) : '/roles-admin';
var _title    = _isEdit ? (_editable ? 'Edit Role' : 'View Role') : 'New Role';
var _disabled = _editable ? '' : 'disabled';

var _actionIcons = { view: 'fa-eye', create: 'fa-plus', edit: 'fa-pen', delete: 'fa-trash-can', export: 'fa-upload' };
%>

<%- include('../partials/page-head', {
    title: _title,
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'Roles', href: '/roles-admin' },
        { label: _title },
    ],
    actions: [
        { label: 'Back to Roles', icon: 'fa-arrow-left', variant: 'light', href: '/roles-admin' },
    ],
}) %>

<% if (!_editable) { %>
    <div class="alert alert-info flash-banner" role="alert">
        <i class="fa-solid fa-circle-info me-2"></i>
        This is a built-in <strong>system role</strong> and cannot be edited. Its effective permissions are shown below.
    </div>
<% } %>

<form id="role-form" method="post" action="<%= _action %>" autocomplete="off">

    <div class="card mb-3">
        <div class="card-body p-4">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="role-name">Role Name<span class="req">*</span></label>
                    <input type="text" class="form-control" id="role-name" name="name"
                           value="<%= _name %>" placeholder="e.g. Branch Accountant"
                           <%= _editable ? 'required' : 'readonly' %>>
                    <% if (_isEdit && _role.slug) { %>
                        <div class="form-hint">Slug: <code><%= _role.slug %></code></div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="inv-section-head">
            <h2 class="inv-section-title">
                <i class="fa-solid fa-table-list me-2 text-primary"></i>Permissions
            </h2>
            <span class="form-hint mb-0">Tick the actions this role can perform per module.</span>
        </div>

        <% if (!_modules.length) { %>
            <div class="data-table-empty text-center text-muted py-5">
                <i class="fa-regular fa-folder-open d-block mb-2 fs-3"></i>
                This license is not entitled to any modules yet.
                <div class="form-hint mt-2">Ask the platform administrator to grant module access to your license.</div>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="rbac-matrix" id="rolerermsMatrix">
                    <thead>
                        <tr>
                            <th>Module</th>
                            <th class="text-start">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% _modules.forEach(function (m) { %>
                            <% var acts = (m && m.actions) ? m.actions : []; %>
                            <tr>
                                <td>
                                    <% if (_editable) { %>
                                        <input type="checkbox" class="me-2" data-row-toggle title="Toggle all">
                                    <% } %>
                                    <%= m.label || m.key %>
                                </td>
                                <td class="text-start">
                                    <div class="role-perm-actions">
                                        <% acts.forEach(function (a) { %>
                                            <% var slug = m.key + '.' + a; %>
                                            <label class="role-perm-chip">
                                                <input type="checkbox" name="perm" value="<%= slug %>"
                                                       <%= _permsSet[slug] ? 'checked' : '' %> <%= _disabled %>>
                                                <i class="fa-solid <%= _actionIcons[a] || 'fa-check' %> me-1"></i><%= a.charAt(0).toUpperCase() + a.slice(1) %>
                                            </label>
                                        <% }); %>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>

    <% if (_editable) { %>
        <div class="form-card-footer">
            <a class="btn btn-light" href="/roles-admin">Cancel</a>
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-floppy-disk me-1"></i><%= _isEdit ? 'Save Role' : 'Create Role' %>
            </button>
        </div>
    <% } %>

</form>

<style>
    /* Inline action chips for the role permission grid — reuses theme tokens
     * (primary accent, border, radius) so it matches the rest of the app. */
    .role-perm-actions { display: flex; flex-wrap: wrap; gap: 8px; }
    .role-perm-chip {
        display: inline-flex; align-items: center; gap: 2px;
        padding: 5px 11px; border: 1px solid var(--border); border-radius: 8px;
        font-size: 13px; color: var(--text); cursor: pointer; user-select: none;
        background: #fff; transition: background .12s, border-color .12s;
    }
    .role-perm-chip:has(input:checked) {
        background: rgba(37,99,235,.08); border-color: var(--primary); color: var(--primary);
    }
    .role-perm-chip input[type="checkbox"] {
        width: 15px; height: 15px; accent-color: var(--primary); cursor: pointer; margin-right: 4px;
    }
    .role-perm-chip input:disabled { cursor: default; }
</style>

<% if (_editable && _modules.length) { %>
<script>
    /* Per-row "select all / none" for the role permission grid. UI only —
     * flips the checkboxes the form already submits. */
    (function () {
        var table = document.getElementById('rolerermsMatrix');
        if (!table) return;
        table.querySelectorAll('[data-row-toggle]').forEach(function (rowCb) {
            rowCb.addEventListener('change', function () {
                var row = rowCb.closest('tr');
                if (!row) return;
                row.querySelectorAll('input[name="perm"]').forEach(function (cb) {
                    cb.checked = rowCb.checked;
                });
            });
        });
    })();
</script>
<% } %>
