<%
/* ─────────────────────────────────────────────────────────────
 * views/companies/form.ejs — MASTERS · Add / Edit Company.
 * Routes: GET /companies/add (create) · GET /companies/:id/edit (edit).
 *
 * Every tab maps to a REAL editable column on the `companies` table —
 * nothing is a "coming next phase" placeholder, and fields that have no
 * backing column (notes, etc.) were removed. Synced Tally values pre-fill
 * the inputs; empty ones stay editable so the user can fill them in.
 *
 * Expected locals (routes/web.js → res.render):
 *   financialYears  [ '2024-2025', … ] — Financial Year select options
 *   company         the row being edited (edit mode)   — optional
 *   editId          the company id (edit mode)          — optional
 * ─────────────────────────────────────────────────────────── */

var _financialYears = (typeof financialYears !== 'undefined' && financialYears) ? financialYears : [];
var C       = (typeof company !== 'undefined' && company) ? company : {};
var _isEdit = (typeof editId !== 'undefined' && editId) ? true : false;
var _act    = _isEdit ? ('/companies/' + editId) : '/companies';
var _pageTitle = _isEdit ? 'Edit Company' : 'Add Company';

/* FormCard tabs (id === the pane id rendered below). */
var formTabs = [
    { id: 'basic',   label: 'Basic Information', icon: 'fa-id-card',          active: true },
    { id: 'address', label: 'Address',           icon: 'fa-map-location-dot'               },
    { id: 'tax',     label: 'Tax & Statutory',   icon: 'fa-percent'                        },
    { id: 'fy',      label: 'Financial Year',    icon: 'fa-calendar-day'                   },
    { id: 'brand',   label: 'Branding',          icon: 'fa-image'                          },
    { id: 'custom',  label: 'Custom Fields',     icon: 'fa-table-cells'                    },
];

/* Flat list → <option>s with a "Select …" sentinel + optional pre-selection. */
function _selOpts(placeholder, list, selected) {
    var sel = selected != null ? String(selected) : '';
    var html = '<option value=""' + (sel ? '' : ' selected') + ' disabled hidden>' + placeholder + '</option>';
    (list || []).forEach(function (v) {
        html += '<option value="' + v + '"' + (String(v) === sel ? ' selected' : '') + '>' + v + '</option>';
    });
    return html;
}

/* Custom Fields bag → key/value rows. */
var _cf = {};
try { _cf = (typeof C.custom_fields === 'string') ? JSON.parse(C.custom_fields || '{}') : (C.custom_fields || {}); } catch (e) { _cf = {}; }
var _cfKeys = Object.keys(_cf);

/* page-head actions: Back link + a Save split button. */
var headActions =
    '<a class="btn btn-light" href="/companies">' +
        '<i class="fa-solid fa-arrow-left me-1"></i>Back to Companies' +
    '</a>' +
    '<button type="submit" form="company-form" class="btn btn-primary">' +
        '<i class="fa-solid fa-floppy-disk me-1"></i>Save Company' +
    '</button>';
%>

<%- include('../partials/page-head', {
    title: _pageTitle,
    breadcrumb: [
        { label: 'Dashboard', href: '/' },
        { label: 'Companies', href: '/companies' },
        { label: _pageTitle },
    ],
    actions: headActions,
}) %>

<form id="company-form" class="card form-card" method="post" action="<%= _act %>" autocomplete="off" novalidate>

    <%- include('../partials/form-card', { tabs: formTabs }) %>

    <div class="tab-content form-card-body">

        <!-- ════ Basic Information ════ -->
        <div class="tab-pane fade show active" id="basic" role="tabpanel" aria-labelledby="basic-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="co-name">Company Name<span class="req">*</span></label>
                    <input type="text" class="form-control" id="co-name" name="name"
                           value="<%= C.name || '' %>" placeholder="Enter company name" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="co-mailing">Mailing Name</label>
                    <input type="text" class="form-control" id="co-mailing" name="mailing_name"
                           value="<%= C.mailing_name || '' %>" placeholder="Name as printed on documents">
                </div>
                <div class="form-group">
                    <label class="form-label" for="co-email">Email</label>
                    <div class="input-affix">
                        <span class="affix affix--prefix"><i class="fa-solid fa-envelope"></i></span>
                        <input type="email" class="form-control" id="co-email" name="email"
                               value="<%= C.email || '' %>" placeholder="name@company.com">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="co-mobile">Mobile Number</label>
                    <div class="input-affix">
                        <span class="affix affix--prefix"><i class="fa-solid fa-mobile-screen"></i></span>
                        <input type="tel" class="form-control" id="co-mobile" name="mobile"
                               value="<%= C.mobile || '' %>" placeholder="98765 43210" maxlength="20">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="co-phone">Phone (Landline)</label>
                    <div class="input-affix">
                        <span class="affix affix--prefix"><i class="fa-solid fa-phone"></i></span>
                        <input type="tel" class="form-control" id="co-phone" name="phone"
                               value="<%= C.phone || '' %>" placeholder="0731-1234567" maxlength="20">
                    </div>
                </div>
            </div>

            <hr class="form-divider">

            <label class="form-label d-block">Status<span class="req">*</span></label>
            <div class="status-radios">
                <label class="status-radio is-active">
                    <input type="radio" name="status" value="Active" <%= (!C.status || C.status === 'Active') ? 'checked' : '' %>>
                    <span>Active</span>
                </label>
                <label class="status-radio is-inactive">
                    <input type="radio" name="status" value="Inactive" <%= C.status === 'Inactive' ? 'checked' : '' %>>
                    <span>Inactive</span>
                </label>
                <label class="status-radio is-blocked">
                    <input type="radio" name="status" value="Blocked" <%= C.status === 'Blocked' ? 'checked' : '' %>>
                    <span>Blocked</span>
                </label>
            </div>
        </div><!-- /#basic -->

        <!-- ════ Address ════ -->
        <div class="tab-pane fade" id="address" role="tabpanel" aria-labelledby="address-tab">
            <div class="row g-4 mb-2">
                <div class="col-12 col-md-8">
                    <label class="form-label" for="co-address">Street Address</label>
                    <textarea class="form-control" id="co-address" name="address"
                              rows="3" maxlength="500"
                              placeholder="Building, street, area, city…"><%= C.address || '' %></textarea>
                </div>
            </div>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="co-state">State</label>
                    <input type="text" class="form-control" id="co-state" name="state"
                           value="<%= C.state || '' %>" placeholder="Gujarat">
                </div>
                <div class="form-group">
                    <label class="form-label" for="co-pincode">Pincode</label>
                    <input type="text" class="form-control" id="co-pincode" name="pincode"
                           value="<%= C.pincode || '' %>" placeholder="382210" maxlength="12">
                </div>
                <div class="form-group">
                    <label class="form-label" for="co-country">Country</label>
                    <input type="text" class="form-control" id="co-country" name="country"
                           value="<%= C.country || '' %>" placeholder="India">
                </div>
            </div>
        </div><!-- /#address -->

        <!-- ════ Tax & Statutory ════ -->
        <div class="tab-pane fade" id="tax" role="tabpanel" aria-labelledby="tax-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="co-gst">GST Number</label>
                    <input type="text" class="form-control text-uppercase" id="co-gst" name="gst_number"
                           value="<%= C.gst_number || '' %>" placeholder="24ABCDE1234F1Z5" maxlength="15">
                </div>
                <div class="form-group">
                    <label class="form-label" for="co-pan">PAN Number</label>
                    <input type="text" class="form-control text-uppercase" id="co-pan" name="pan_number"
                           value="<%= C.pan_number || '' %>" placeholder="ABCDE1234F" maxlength="10">
                </div>
            </div>
        </div><!-- /#tax -->

        <!-- ════ Financial Year ════ -->
        <div class="tab-pane fade" id="fy" role="tabpanel" aria-labelledby="fy-tab">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" for="co-fy">Financial Year</label>
                    <select class="form-select" id="co-fy" name="financial_year">
                        <%- _selOpts('Select financial year', _financialYears, (C.financial_year || '')) %>
                    </select>
                    <div class="form-hint">The active books year synced from Tally.</div>
                </div>
                <div class="form-group">
                    <label class="form-label" for="co-booksfrom">Books Beginning From</label>
                    <input type="text" class="form-control" id="co-booksfrom" name="books_from"
                           value="<%= C.books_from || '' %>" placeholder="2024-04-01">
                    <div class="form-hint">The books-beginning date as in Tally.</div>
                </div>
            </div>
        </div><!-- /#fy -->

        <!-- ════ Branding ════ -->
        <div class="tab-pane fade" id="brand" role="tabpanel" aria-labelledby="brand-tab">
            <% if (C.logo) { %>
                <div class="mb-3">
                    <label class="form-label d-block">Current Logo</label>
                    <img src="<%= C.logo %>" alt="Company logo" style="max-height:72px;border:1px solid #e5e7eb;border-radius:8px;padding:4px;">
                </div>
            <% } %>
            <div class="row g-4">
                <div class="col-12 col-md-5">
                    <label class="form-label d-block" for="co-logo">Company Logo</label>
                    <input type="file" class="form-control" id="co-logo" name="logo" accept="image/*">
                    <div class="form-hint">PNG/JPG/SVG, up to 1&nbsp;MB. Shown on invoices.</div>
                </div>
            </div>
        </div><!-- /#brand -->

        <!-- ════ Custom Fields (dynamic key/value editor) ════ -->
        <div class="tab-pane fade" id="custom" role="tabpanel" aria-labelledby="custom-tab">
            <%- include('../partials/custom-fields', { cf: _cf, noun: 'company' }) %>
        </div><!-- /#custom -->

    </div><!-- /.tab-content -->

    <div class="form-card-footer">
        <a class="btn btn-light" href="/companies">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-floppy-disk me-1"></i>Save Company
        </button>
    </div>

</form>
