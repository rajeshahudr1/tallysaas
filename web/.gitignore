# ─────────────────────────────────────────────────────────────
# .gitignore — tallysaas web tier
# Keep dependencies, secrets and runtime logs out of version control.
# ─────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Local environment / secrets
.env
.env.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
