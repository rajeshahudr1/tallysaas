# ── Tally Cloud Sync — WEB (BFF) environment ──
PORT=4600
API_URL=http://localhost:4500/api/v1

# ── Session store (connect-pg-simple) — point at the SAME Postgres as the api ──
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=tallysaas
DB_USERNAME=postgres
DB_PASSWORD=
# DB_SSL=true                      # enable for managed Postgres over TLS
# DB_SSL_REJECT_UNAUTHORIZED=false # only for self-signed certs (debug)

SESSION_SECRET=change_me_to_a_long_random_string
SESSION_MAX_AGE=28800000          # 8h in ms
COOKIE_SECURE=false               # set true ONLY behind HTTPS + a proxy forwarding X-Forwarded-Proto
TRUST_PROXY=1                     # number of proxy hops in front of Node (Nginx=1)
SESSION_DEBUG=0                   # 1 = per-request login diagnostics in the logs
