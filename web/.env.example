# ─────────────────────────────────────────────────────────────
# .env.example — copy to `.env` and adjust as needed.
# The Phase-1 UI is mock-only, so only PORT actually matters today.
# API_URL is reserved for when the mock layer is swapped for a real
# apiClient that calls the REST API (see README → "Swapping mock → API").
# ─────────────────────────────────────────────────────────────

# Port the Express UI server listens on.
PORT=4600

# Base URL of the REST API (used later by the apiClient — not yet wired).
API_URL=http://localhost:4500
