# ─────────────────────────────────────────────────────────────
# Tally Cloud Sync — .gitignore
# Keep secrets + heavy/generated artifacts OUT of the repo.
# ─────────────────────────────────────────────────────────────

# Dependencies
node_modules/
**/node_modules/

# Secrets / environment — NEVER commit (templates *.example are kept)
.env
**/.env
*.env
!**/*.env.example
!.env.example

# Agent runtime config (holds agent_token + machine fingerprint) + logs
agent/config.ini
**/logs/
*.log
# Agent single-instance runtime lock
**/tally_cloud_sync.lock

# Published/uploaded agent release binaries (runtime artifacts served to agents)
# Keep the folder (.gitkeep) but never commit the uploaded exe files.
api/agent-releases/*
!api/agent-releases/.gitkeep

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
# PyInstaller build output
agent/build/
agent/dist/
*.spec

# Sessions / uploads / runtime
**/uploads/
*.sqlite
*.sqlite3

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.bak
*.tmp
