APP_ENV=development
PORT=4500
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=tallysaas
DB_USERNAME=postgres
DB_PASSWORD=
JWT_SECRET=change-me-to-a-48-char-random-base64url-string-aaaaaaaa
JWT_EXPIRES_IN=24h
CORS_ORIGIN=*
WEB_ORIGIN=http://localhost:4600

# Agent auto-update (Requirement 1). AGENT_RELEASE_DIR is the folder that holds
# the published TallyCloudSyncAgent.exe files (default api/agent-releases/). A
# super-admin drops the freshly-built exe there, then publishes its version via
# POST /super-admin/agent-release. AGENT_LATEST_VERSION is only a fallback for
# GET /agent/version when nothing is published in the DB yet.
AGENT_RELEASE_DIR=
AGENT_LATEST_VERSION=

# License-key encryption (super-admin reveal/regenerate). AES-256-GCM key is
# derived as sha256(LICENSE_KEY_SECRET); the full license key is stored
# reversibly-encrypted (licenses.license_key_enc) so a super-admin can VIEW it.
# Use a FRESH 64-hex (32-byte) random value, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep it secret and stable — changing it makes previously-stored keys
# unrevealable (the detail page falls back to Regenerate). NEVER commit .env.
LICENSE_KEY_SECRET=replace-with-64-hex-secret

# Toggleable agent diagnostics — logs what each agent sent + what the cloud did with it.
AGENT_DEBUG=0
